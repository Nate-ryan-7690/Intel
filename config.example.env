# Intel Pipeline — Environment Configuration
# Copy this file to .env and fill in your real values
# Never commit .env to the repository

# abuse.ch API key (covers MalwareBazaar, URLhaus, ThreatFox, Feodo Tracker)
# Register at: https://auth.abuse.ch
ABUSE_CH_API_KEY=your_abuse_ch_api_key_here

# AlienVault OTX API key
# Register at: https://otx.alienvault.com
OTX_API_KEY=your_otx_api_key_here

# GreyNoise API key (community tier — enrichment only)
# Register at: https://greynoise.io
# Leave blank to use unauthenticated endpoint (10 lookups/day)
GREYNOISE_API_KEY=your_greynoise_api_key_here

# Flask configuration
FLASK_PORT=6001
FLASK_DEBUG=False
